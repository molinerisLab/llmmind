configfile: "config/config.yaml"

rule download_llm:
    output:
        directory("resources/models/{model_name}")
    shell:
        r"""
            workflow/scripts/save_pretrained.py {wildcards.model_name} {output}
        """

rule embed:
    input:
        model_dir="resources/models/{model_name}",
        input_dir="resources/stimuli"
    output:
        "results/embeddings/{model_name}_embeddings.parquet"
    params:
        quantization_method=config["quantization_method"]
    conda:
        "envs/embed_environment.yaml"
    shell:
        r"""
            workflow/scripts/embed.py \
                --input_dir {input.input_dir} \
                --output {output} \
                --model_path {input.model_dir} \
                --quantization_method {params.quantization_method}
        """